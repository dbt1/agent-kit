#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  LINK_TARGET="$(readlink "$SOURCE")"
  if [[ "$LINK_TARGET" = /* ]]; then
    SOURCE="$LINK_TARGET"
  else
    SOURCE="$(cd "$(dirname "$SOURCE")" && cd "$(dirname "$LINK_TARGET")" && pwd)/$(basename "$LINK_TARGET")"
  fi
done

SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
AGENT_KIT_HOME="${AGENT_KIT_HOME:-$(cd "$SCRIPT_DIR/.." && pwd)}"
BOOTSTRAP_SCRIPT="$AGENT_KIT_HOME/bootstrap/bootstrap.sh"
SELF_REAL="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || printf '%s' "$0")"
CMD_NAME="$(basename "$0")"
FORCE_ROOTS="${AGENT_KIT_AUTOBOOTSTRAP_FORCE_ROOTS:-}"

resolve_real_cmd() {
  local cmd="$1"
  local env_name env_value

  env_name="AGENT_KIT_REAL_$(printf '%s' "$cmd" | tr '[:lower:]' '[:upper:]' | tr -cs 'A-Z0-9' '_')"
  env_value="${!env_name:-}"
  if [ -n "$env_value" ] && [ -x "$env_value" ]; then
    printf '%s\n' "$env_value"
    return 0
  fi

  local candidate candidate_real
  while IFS= read -r candidate; do
    [ -n "$candidate" ] || continue
    candidate_real="$(readlink -f "$candidate" 2>/dev/null || realpath "$candidate" 2>/dev/null || printf '%s' "$candidate")"
    if [ "$candidate_real" = "$SELF_REAL" ]; then
      continue
    fi
    printf '%s\n' "$candidate"
    return 0
  done < <(which -a "$cmd" 2>/dev/null | awk '!seen[$0]++')

  return 1
}

normalize_dir() {
  local dir="$1"
  [ -n "$dir" ] || return 1
  if [ -d "$dir" ]; then
    (cd "$dir" && pwd -P)
    return 0
  fi
  local parent base
  parent="$(dirname "$dir")"
  base="$(basename "$dir")"
  if [ ! -d "$parent" ]; then
    return 1
  fi
  printf '%s/%s\n' "$(cd "$parent" && pwd -P)" "$base"
}

should_force_bootstrap() {
  [ -n "$FORCE_ROOTS" ] || return 1
  local project_root normalized_project normalized_root
  project_root="$(git rev-parse --show-toplevel 2>/dev/null)" || return 1
  normalized_project="$(normalize_dir "$project_root")" || return 1

  local old_ifs
  old_ifs="$IFS"
  IFS="${AGENT_KIT_PATH_SEPARATOR:-:}"
  for root in $FORCE_ROOTS; do
    [ -n "$root" ] || continue
    normalized_root="$(normalize_dir "$root" 2>/dev/null)" || continue
    if [ "$normalized_project" = "$normalized_root" ]; then
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"
  return 1
}

if [ "${AGENT_KIT_AUTOBOOTSTRAP:-1}" = "1" ] && [ -x "$BOOTSTRAP_SCRIPT" ]; then
  BOOTSTRAP_ARGS=(--agent "$CMD_NAME" --quiet)
  if should_force_bootstrap; then
    BOOTSTRAP_ARGS+=(--force)
  fi
  "$BOOTSTRAP_SCRIPT" "${BOOTSTRAP_ARGS[@]}" || true
fi

if ! REAL_CMD="$(resolve_real_cmd "$CMD_NAME")"; then
  echo "agent-wrapper: unable to resolve real command for '$CMD_NAME'" >&2
  exit 127
fi

exec "$REAL_CMD" "$@"
